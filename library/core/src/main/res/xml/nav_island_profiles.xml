<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:myLocation="@string/nav_island_profiles_title"
    app:quick_restart="com.android.systemui">

    <PreferenceCategory android:title="@string/nav_island_profiles_title">

        <Preference
            android:key="prefs_key_nav_island_profile_save"
            android:summary="@string/nav_island_profile_save_summary"
            android:title="@string/nav_island_profile_save" />

        <Preference
            android:key="prefs_key_nav_island_profile_export"
            android:summary="@string/nav_island_profile_export_summary"
            android:title="@string/nav_island_profile_export" />

        <Preference
            android:key="prefs_key_nav_island_profile_import"
            android:summary="@string/nav_island_profile_import_summary"
            android:title="@string/nav_island_profile_import" />

        <Preference
            android:key="prefs_key_nav_island_profile_reset"
            android:summary="@string/nav_island_profile_reset_summary"
            android:title="@string/nav_island_profile_reset" />

    </PreferenceCategory>

</PreferenceScreen>
