<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:myLocation="@string/nav_island_title"
    app:quick_restart="com.android.systemui">

    <PreferenceCategory>

        <!-- Master enable toggle — everything else depends on this -->
        <SwitchPreference
            android:defaultValue="false"
            android:key="prefs_key_nav_island_enable"
            android:summary="@string/nav_island_enable_summary"
            android:title="@string/nav_island_enable" />

        <!-- Glass Effect sub-page -->
        <Preference
            android:dependency="prefs_key_nav_island_enable"
            android:fragment="com.sevtinge.hyperceiler.hooker.systemui.navIsland.NavIslandGlassSettings"
            android:title="@string/nav_island_glass_title" />

        <!-- Layout sub-page -->
        <Preference
            android:dependency="prefs_key_nav_island_enable"
            android:fragment="com.sevtinge.hyperceiler.hooker.systemui.navIsland.NavIslandLayoutSettings"
            android:title="@string/nav_island_layout_title" />

        <!-- Colors sub-page -->
        <Preference
            android:dependency="prefs_key_nav_island_enable"
            android:fragment="com.sevtinge.hyperceiler.hooker.systemui.navIsland.NavIslandColorSettings"
            android:title="@string/nav_island_colors_title" />

        <!-- Animations sub-page -->
        <Preference
            android:dependency="prefs_key_nav_island_enable"
            android:fragment="com.sevtinge.hyperceiler.hooker.systemui.navIsland.NavIslandAnimSettings"
            android:title="@string/nav_island_anim_title" />

        <!-- Profiles sub-page -->
        <Preference
            android:dependency="prefs_key_nav_island_enable"
            android:fragment="com.sevtinge.hyperceiler.hooker.systemui.navIsland.NavIslandProfileSettings"
            android:title="@string/nav_island_profiles_title" />

    </PreferenceCategory>

</PreferenceScreen>
